# ═══════════════════════════════════════════════════════════════════════════════
# PlaywrightProject .gitignore
# 7 Laws of QA Automation — Law 3: Repeatability (no local state committed)
# ADR-009: Auth state must never be committed
# ═══════════════════════════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
coverage/

# ── Playwright test outputs ────────────────────────────────────────────────────
test-results/
playwright-report/
.playwright/
blob-report/

# ── Allure reporting ──────────────────────────────────────────────────────────
allure-results/
allure-report/

# ── Pact contracts (generated locally / in CI; published to broker) ───────────
pacts/

# ── Visual regression artifacts ────────────────────────────────────────────────
*.png
*.mp4
*.webm
*.trace.zip

# ── Auth state (ADR-009) ──────────────────────────────────────────────────────
.auth/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
output/
tmp/

# ── Database artifacts ────────────────────────────────────────────────────────
*.db
*.sqlite

# ── Data results ──────────────────────────────────────────────────────────────
data/results/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# ── IDE files ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~

# ── Lock files from other ecosystems ──────────────────────────────────────────
package-lock.json
