# ═══════════════════════════════════════════════════════════════════════════════
# PlaywrightProject .gitignore
# 7 Laws of QA Automation — Law 3: Repeatability (no local state committed)
# ADR-009: Auth state must never be committed
# ═══════════════════════════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
coverage/

# ── Playwright test outputs ────────────────────────────────────────────────────
test-results/
playwright-report/
.playwright/
blob-report/

# ── Allure reporting ──────────────────────────────────────────────────────────
allure-results/
allure-report/

# ── Visual regression artifacts ────────────────────────────────────────────────
# NOTE: Visual baselines must be committed for true regression testing.
# Generated media is already covered by ignored output folders above (test-results/, allure-results/, etc.).

# ── Auth state (ADR-009) ──────────────────────────────────────────────────────
.auth/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.ai.example

# AI heal cache (ADR-019)
.ai-heal-cache/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
output/
tmp/

# ── Database artifacts ────────────────────────────────────────────────────────
*.db
*.sqlite

# ── Data results ──────────────────────────────────────────────────────────────
data/results/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# ── IDE files ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~

# ── Lock files from other ecosystems ──────────────────────────────────────────
package-lock.json
