{
  "name": "playwrightproject",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "main": "index.js",
  "scripts": {
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "vitest run tests/unit/",
    "test:unit:watch": "vitest tests/unit/",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:sauce": "playwright test tests/ui/sauce/",
    "test:practice": "playwright test tests/ui/practice/",
    "test:backend": "playwright test tests/backend/",
    "test:a11y": "playwright test tests/accessibility/",
    "test:visual": "playwright test tests/ui/visual/",
    "test:perf": "playwright test tests/performance/",
    "test:integration": "playwright test tests/integration/",
    "test:schema-validation": "playwright test tests/backend/schema-validation.spec.ts",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "echo \"Not implemented: firefox project is not defined in playwright.config.ts\" && exit 1",
    "test:webkit": "echo \"Not implemented: webkit project is not defined in playwright.config.ts\" && exit 1",
    "test:all-browsers": "echo \"Not implemented: only chromium is configured by default\" && exit 1",
    "report": "playwright show-report",
    "report:allure": "allure generate allure-results --clean && allure open allure-report",
    "snapshots:update": "playwright test --update-snapshots",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "depcruise": "depcruise --config .dependency-cruiser.cjs pages locators tests/ui tests/backend tests/accessibility tests/performance tests/integration tests/auth utils",
    "prepare": "husky install",
    "clean": "rm -rf dist test-results allure-results allure-report playwright-report",
    "ai:init-agents": "playwright init-agents --loop=vscode",
    "ai:promote-heal": "node scripts/promote-healed-locator.mjs",
    "ai:triage": "node scripts/ai-triage-failure.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix --max-warnings=100",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/css": "^0.13.0",
    "@eslint/js": "^9.37.0",
    "@faker-js/faker": "^9.8.0",
    "@playwright/test": "^1.56.0",
    "@types/pngjs": "^6.0.5",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.4.1",
    "axios": "^1.12.2",
    "dependency-cruiser": "^16.10.2",
    "eslint": "^9.37.0",
    "eslint-plugin-playwright": "^2.4.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.4.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.2.4",
    "pino": "^10.0.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.56.0",
    "playwright-bdd": "^8.4.2",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.206.0",
    "@opentelemetry/instrumentation": "^0.206.0",
    "@opentelemetry/instrumentation-http": "^0.206.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.5.0",
    "dotenv": "^17.2.3",
    "winston": "^3.18.3"
  }
}
